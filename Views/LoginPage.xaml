<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Mercurio.Driver.Views.LoginPage"
             xmlns:viewmodels="clr-namespace:Mercurio.Driver.ViewModels"
             xmlns:converters="clr-namespace:Mercurio.Driver.Converters"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
            <converters:StringToBoolConverter x:Key="StringToBoolConverter" />

            <!-- Colors -->
            <Color x:Key="PageBackgroundColor">#E2E1E1</Color>
            <Color x:Key="AngelBlue">#0C517A</Color>

            <Color x:Key="CardBackgroundColor">#F2FFFFFF</Color>
            <Color x:Key="CardStrokeColor">#220C517A</Color>
            <Color x:Key="EntryFillColor">#140C517A</Color>
            <Color x:Key="EntryStrokeColor">#220C517A</Color>

            <Color x:Key="PrimaryTextColor">#0C517A</Color>
            <Color x:Key="PlaceholderColor">#7A0C517A</Color>

            <Color x:Key="ButtonTextColor">#FFFFFF</Color>
            <Color x:Key="ButtonBackgroundColor">#0C517A</Color>

            <Color x:Key="ErrorColor">#D64040</Color>

            <Style TargetType="Label" x:Key="IconLabelStyle">
                <Setter Property="FontFamily" Value="FontAwesomeSolid" />
                <Setter Property="FontSize" Value="18" />
                <Setter Property="VerticalTextAlignment" Value="Center" />
                <Setter Property="HorizontalTextAlignment" Value="Center" />
                <Setter Property="TextColor" Value="{StaticResource PrimaryTextColor}" />
                <Setter Property="Margin" Value="0,0,8,0"/>
            </Style>

            <Style TargetType="Entry">
                <Setter Property="TextColor" Value="{StaticResource PrimaryTextColor}" />
                <Setter Property="PlaceholderColor" Value="{StaticResource PlaceholderColor}" />
                <Setter Property="BackgroundColor" Value="Transparent"/>
                <Setter Property="VerticalTextAlignment" Value="Center"/>
                <Setter Property="HeightRequest" Value="52"/>
                <Setter Property="FontSize" Value="16"/>
            </Style>

            <Style TargetType="Button" x:Key="LinkButton">
                <Setter Property="TextColor" Value="{StaticResource AngelBlue}"/>
                <Setter Property="BackgroundColor" Value="Transparent"/>
                <Setter Property="FontSize" Value="Small"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="FontAttributes" Value="Bold"/>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <!-- IMPORTANTE: BackgroundColor aquí, después de Resources -->
    <ContentPage.BackgroundColor>
        <StaticResource Key="PageBackgroundColor" />
    </ContentPage.BackgroundColor>

    <ContentPage.BindingContext>
        <viewmodels:LoginViewModel />
    </ContentPage.BindingContext>

    <Grid BackgroundColor="{StaticResource PageBackgroundColor}">
        <ScrollView>
            <VerticalStackLayout Padding="10,0"
                                 Spacing="10"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Fill">

                <Image Source="logo.png"
                       Aspect="AspectFit"
                       WidthRequest="190"
                       HeightRequest="190"
                       HorizontalOptions="Center"/>

                <Label Text="RAPHAEL"
                       TextColor="{StaticResource AngelBlue}"
                       FontSize="12"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       Margin="0,-45,0,10"/>

                <Label Text="by Milanes Transport LLC"
                       TextColor="{StaticResource AngelBlue}"
                       FontSize="12"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       Margin="0,-10,0,18"/>

                <Border BackgroundColor="{StaticResource CardBackgroundColor}"
                        Stroke="{StaticResource CardStrokeColor}"
                        StrokeThickness="1"
                        Padding="22"
                        StrokeShape="RoundRectangle 24"
                        HorizontalOptions="Fill"
                        Margin="4,0">

                    <VerticalStackLayout Spacing="18">

                        <Border BackgroundColor="{StaticResource EntryFillColor}"
                                Stroke="{StaticResource EntryStrokeColor}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 18"
                                Padding="14,0,10,0"
                                HeightRequest="52">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                <Label Text="" Style="{StaticResource IconLabelStyle}" />
                                <Entry Grid.Column="1"
                                       Placeholder="Username"
                                       Text="{Binding Username}" />
                            </Grid>
                        </Border>

                        <Border BackgroundColor="{StaticResource EntryFillColor}"
                                Stroke="{StaticResource EntryStrokeColor}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 18"
                                Padding="14,0,10,0"
                                HeightRequest="52">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                <Label Text="" Style="{StaticResource IconLabelStyle}" />
                                <Entry Grid.Column="1"
                                       Placeholder="Password"
                                       Text="{Binding Password}"
                                       IsPassword="{Binding IsPasswordMasked}" />
                                <Button Grid.Column="2"
                                        Text="{Binding PasswordToggleIcon}"
                                        FontFamily="FontAwesomeSolid"
                                        FontSize="18"
                                        Command="{Binding TogglePasswordMaskCommand}"
                                        BackgroundColor="Transparent"
                                        TextColor="{StaticResource AngelBlue}"
                                        Padding="6"
                                        WidthRequest="40"
                                        BorderColor="Transparent"
                                        BorderWidth="0"
                                        VerticalOptions="Center"/>
                            </Grid>
                        </Border>

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" Margin="0,2,0,0">
                            <CheckBox IsChecked="{Binding RememberMe}"
                                      Color="{StaticResource AngelBlue}" />
                            <Label Grid.Column="1"
                                   Text="Remember me"
                                   TextColor="{StaticResource AngelBlue}"
                                   VerticalTextAlignment="Center"
                                   FontSize="Small"/>
                        </Grid>

                        <!-- Botón + loader iOS-like que sustituye el texto -->
                        <Grid HeightRequest="56" Margin="0,6,0,0">

                            <!-- Botón real (lógica intacta) -->
                            <Button Text=""
                                    Command="{Binding LoginCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                                    BackgroundColor="{StaticResource ButtonBackgroundColor}"
                                    TextColor="{StaticResource ButtonTextColor}"
                                    HeightRequest="56"
                                    CornerRadius="18"
                                    FontSize="18"
                                    FontAttributes="Bold"
                                    Padding="14,0" />

                            <!-- Texto (solo cuando NO está busy) -->
                            <Label Text="Log In"
                                   InputTransparent="True"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   TextColor="{StaticResource ButtonTextColor}"
                                   FontSize="18"
                                   FontAttributes="Bold">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label"
                                                 Binding="{Binding IsBusy}"
                                                 Value="True">
                                        <Setter Property="IsVisible" Value="False" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>

                            <!-- Spinner (solo cuando está busy) -->
                            <ActivityIndicator InputTransparent="True"
                                               IsRunning="{Binding IsBusy}"
                                               IsVisible="{Binding IsBusy}"
                                               Color="{StaticResource ButtonTextColor}"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />
                        </Grid>


                        <Label Text="{Binding ErrorMessage}"
                               TextColor="{StaticResource ErrorColor}"
                               HorizontalOptions="Center"
                               Margin="0,4,0,0"
                               IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}"/>

                    </VerticalStackLayout>
                </Border>

                <HorizontalStackLayout Spacing="6"
                                       HorizontalOptions="Center"
                                       Margin="0,22,0,25">
                    <Label Text="RAPHAEL by"
                           TextColor="{StaticResource AngelBlue}"
                           VerticalTextAlignment="Center"/>
                    <Button Text="Milanes Transport"
                            Command="{Binding GoToMilanesPageCommand}"
                            Style="{StaticResource LinkButton}" />
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
